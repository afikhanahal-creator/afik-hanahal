# URL of your Render server (no trailing slash).
# Set this in Vercel → Project Settings → Environment Variables.
# Leave empty to use localStorage-only mode (useful for local dev without the server).
VITE_API_URL=https://afik-hanahal-server.onrender.com

# Image CDN used to proxy/optimise property photos served from Supabase Storage.
# It fetches each image from Supabase ONCE, caches it at the edge, and serves a
# resized + compressed WebP copy to every visitor — this is what keeps Supabase
# egress inside the free tier (otherwise every browser pulls full-size originals
# straight from Supabase on every page view).
# Default: https://wsrv.nl (free, no account). Set to empty to disable proxying.
VITE_IMG_CDN=https://wsrv.nl
